VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated list of Google account emails allowed to manage the ad
# whitelist from the in-app admin panel. This only gates the UI — you must
# also restrict writes to the `adWhitelist` Firestore collection to these
# same accounts via security rules.
VITE_ADMIN_EMAILS=

# ── Netlify function env vars (server-only — set these in the Netlify site's
# environment variables, not in the client build; do NOT prefix with VITE_) ──
# Stripe secret key for your account/mode (test or live).
STRIPE_SECRET_KEY=
# Signing secret from the Stripe webhook endpoint (dashboard.stripe.com/webhooks).
STRIPE_WEBHOOK_SECRET=
# Price ID for the "Remove Ads" product. Create it by running:
#   STRIPE_SECRET_KEY=sk_test_... node scripts/create-remove-ads-product.mjs
STRIPE_PRICE_ID=
# Firebase Admin service account (Firebase Console → Project settings →
# Service accounts → Generate new private key). Keep the \n escapes as-is.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

