# Comma-separated list of Google account emails allowed to manage the ad
# whitelist from the in-app admin panel. This only gates the UI — you must
# also restrict writes to the `adWhitelist` Firestore collection to these
# same accounts via security rules.
VITE_ADMIN_EMAILS=
